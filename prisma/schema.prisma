// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Better Auth required models
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions   Session[]
  accounts   Account[]
  advertiser Advertiser?
  publisher  Publisher?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ===================== Vara Ads DSP =====================

model Advertiser {
  id            String     @id @default(cuid())
  userId        String     @unique
  projectName   String
  websiteUrl    String?
  contractAddrs String[]
  chain         Chain      @default(ETHEREUM)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]
  wallet        Wallet?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("advertiser")
}

model Wallet {
  id                      String              @id @default(cuid())
  advertiserId            String              @unique
  balanceUsdcCents        Int                 @default(0)
  pendingUsdcCents        Int                 @default(0)
  reservedUsdcCents       Int                 @default(0)
  totalDepositedUsdcCents Int                 @default(0)
  totalSpentUsdcCents     Int                 @default(0)
  advertiser              Advertiser          @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  deposits                Deposit[]
  transactions            WalletTransaction[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@map("wallet")
}

model Deposit {
  id              String         @id @default(cuid())
  walletId        String
  chain           Chain          @default(ETHEREUM)
  network         DepositNetwork @default(SEPOLIA)
  txHash          String         @unique
  fromAddress     String
  toAddress       String
  amountUsdcCents Int
  status          DepositStatus  @default(CONFIRMED)
  blockNumber     Int?
  confirmedAt     DateTime?
  wallet          Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([walletId])
  @@map("deposit")
}

model WalletTransaction {
  id              String         @id @default(cuid())
  walletId        String
  type            WalletTxType
  status          WalletTxStatus @default(COMPLETED)
  amountUsdcCents Int
  description     String
  source          String
  txHash          String?
  depositId       String?
  occurredAt      DateTime       @default(now())
  wallet          Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, occurredAt])
  @@map("wallet_transaction")
}

enum DepositNetwork {
  MAINNET
  SEPOLIA
}

enum DepositStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum WalletTxType {
  DEPOSIT
  AD_SPEND
  REFUND
  WITHDRAWAL
}

enum WalletTxStatus {
  PENDING
  COMPLETED
  FAILED
}

// ===================== Vara Ads SSP =====================

model Publisher {
  id          String            @id @default(cuid())
  userId      String            @unique
  siteName    String
  primaryUrl  String?
  category    InventoryCategory @default(OTHER)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  placements  Placement[]
  wallet      PublisherWallet?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("publisher")
}

model Placement {
  id                  String             @id @default(cuid())
  publisherId         String
  name                String
  format              AdFormat
  chains              Chain[]
  status              PlacementStatus    @default(LIVE)
  width               Int?
  height              Int?
  floorPriceUsdcCents Int                @default(0)
  publisher           Publisher          @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  earnings            PublisherEarning[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([publisherId])
  @@map("placement")
}

model PublisherWallet {
  id                      String               @id @default(cuid())
  publisherId             String               @unique
  payoutAddress           String?
  payoutChain             Chain                @default(BASE)
  payoutNetwork           DepositNetwork       @default(SEPOLIA)
  revShareBps             Int                  @default(7000)
  availableUsdcCents      Int                  @default(0)
  pendingUsdcCents        Int                  @default(0)
  lifetimeEarnedUsdcCents Int                  @default(0)
  lifetimePaidUsdcCents   Int                  @default(0)
  publisher               Publisher            @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  earnings                PublisherEarning[]
  payouts                 Payout[]
  statements              PublisherStatement[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@map("publisher_wallet")
}

model PublisherEarning {
  id                String              @id @default(cuid())
  publisherWalletId String
  placementId       String?
  statementId       String?
  date              DateTime            @db.Date
  impressions       Int                 @default(0)
  clicks            Int                 @default(0)
  grossUsdcCents    Int                 @default(0)
  feeUsdcCents      Int                 @default(0)
  netUsdcCents      Int                 @default(0)
  status            EarningStatus       @default(PENDING)
  publisherWallet   PublisherWallet     @relation(fields: [publisherWalletId], references: [id], onDelete: Cascade)
  placement         Placement?          @relation(fields: [placementId], references: [id], onDelete: SetNull)
  statement         PublisherStatement? @relation(fields: [statementId], references: [id], onDelete: SetNull)
  createdAt         DateTime            @default(now())

  @@index([publisherWalletId, date])
  @@index([statementId])
  @@map("publisher_earning")
}

model PublisherStatement {
  id                String             @id @default(cuid())
  publisherWalletId String
  periodStart       DateTime           @db.Date
  periodEnd         DateTime           @db.Date
  impressions       Int                @default(0)
  clicks            Int                @default(0)
  grossUsdcCents    Int                @default(0)
  feeUsdcCents      Int                @default(0)
  netUsdcCents      Int                @default(0)
  status            StatementStatus    @default(OPEN)
  publisherWallet   PublisherWallet    @relation(fields: [publisherWalletId], references: [id], onDelete: Cascade)
  earnings          PublisherEarning[]
  payouts           Payout[]
  createdAt         DateTime           @default(now())
  finalizedAt       DateTime?

  @@index([publisherWalletId, periodStart])
  @@map("publisher_statement")
}

model Payout {
  id                String              @id @default(cuid())
  publisherWalletId String
  statementId       String?
  chain             Chain
  network           DepositNetwork      @default(SEPOLIA)
  amountUsdcCents   Int
  feeUsdcCents      Int                 @default(0)
  toAddress         String
  txHash            String?             @unique
  status            PayoutStatus        @default(PENDING)
  failureReason     String?
  initiatedAt       DateTime            @default(now())
  settledAt         DateTime?
  publisherWallet   PublisherWallet     @relation(fields: [publisherWalletId], references: [id], onDelete: Cascade)
  statement         PublisherStatement? @relation(fields: [statementId], references: [id], onDelete: SetNull)

  @@index([publisherWalletId, initiatedAt])
  @@map("payout")
}

enum EarningStatus {
  PENDING
  CLEARED
  PAID
  REVERSED
}

enum StatementStatus {
  OPEN
  FINALIZED
  PAID
}

enum PayoutStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum PlacementStatus {
  DRAFT
  LIVE
  PAUSED
}

enum AdFormat {
  BANNER
  NATIVE
  INTERSTITIAL
  WALLET_CONTEXTUAL
  VIDEO
}

enum InventoryCategory {
  DEFI
  NFT
  GAMING
  NEWS
  SOCIAL
  TOOLS
  OTHER
}

model Campaign {
  id                    String         @id @default(cuid())
  advertiserId          String
  name                  String
  description           String?
  vertical              Vertical
  status                CampaignStatus @default(DRAFT)
  objective             Objective
  pricingModel          PricingModel   @default(CPM)
  bidStrategy           BidStrategy    @default(MANUAL)
  pacing                Pacing         @default(STANDARD)
  budgetUsdCents        Int
  reservedUsdcCents     Int            @default(0)
  spentUsdcCents        Int            @default(0)
  dailyCapUsdCents      Int?
  bidUsdCents           Int
  frequencyCapPerWallet Int?
  frequencyCapHours     Int?
  startDate             DateTime
  endDate               DateTime?
  conversionContract    String?
  conversionEvent       String?
  conversionWindowDays  Int?
  brandSafetyKeywords   String[]
  advertiser            Advertiser     @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  creatives             Creative[]
  targeting             Targeting?
  adGroups              AdGroup[]
  metrics               MetricDaily[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([advertiserId, status])
  @@map("campaign")
}

model AdGroup {
  id               String         @id @default(cuid())
  campaignId       String
  name             String
  status           CampaignStatus @default(DRAFT)
  bidUsdCents      Int
  pricingModel     PricingModel   @default(CPM)
  bidStrategy      BidStrategy    @default(MANUAL)
  dailyCapUsdCents Int?
  startDate        DateTime?
  endDate          DateTime?
  campaign         Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  targeting        AdGroupTargeting?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([campaignId])
  @@map("ad_group")
}

model AdGroupTargeting {
  id                   String       @id @default(cuid())
  adGroupId            String       @unique
  chains               Chain[]
  geos                 String[]
  deviceTypes          DeviceType[]
  segmentIds           String[]
  holdsAnyContract     String[]
  excludesContracts    String[]
  adGroup              AdGroup      @relation(fields: [adGroupId], references: [id], onDelete: Cascade)

  @@map("ad_group_targeting")
}

model Creative {
  id               String         @id @default(cuid())
  campaignId       String
  name             String
  format           CreativeFormat
  width            Int
  height           Int
  assetUrl         String
  clickUrl         String
  walletConnectCta Boolean        @default(false)
  campaign         Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@index([campaignId])
  @@map("creative")
}

model Targeting {
  id                   String       @id @default(cuid())
  campaignId           String       @unique
  chains               Chain[]
  geos                 String[]
  deviceTypes          DeviceType[]
  segmentIds           String[]
  minWalletAgeDays     Int?
  minPortfolioUsdCents Int?
  holdsAnyContract     String[]
  excludesContracts    String[]
  campaign             Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("targeting")
}

model WalletSegment {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  chain       Chain?
  estSize     Int
  createdAt   DateTime @default(now())

  @@map("wallet_segment")
}

model MetricDaily {
  id             String   @id @default(cuid())
  campaignId     String
  date           DateTime @db.Date
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  walletConnects Int      @default(0)
  onChainConvs   Int      @default(0)
  spendUsdCents  Int      @default(0)
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([date])
  @@map("metric_daily")
}

model AttributionEvent {
  id            String        @id @default(cuid())
  campaignId    String
  walletHash    String
  eventType     AttrEventType
  txHash        String?
  chain         Chain?
  valueUsdCents Int?
  occurredAt    DateTime

  @@index([campaignId, occurredAt])
  @@index([walletHash])
  @@map("attribution_event")
}

enum Chain {
  ETHEREUM
  POLYGON
  SOLANA
  BASE
  ARBITRUM
  OPTIMISM
  BSC
  AVALANCHE
}

enum Vertical {
  TOKEN_LAUNCH
  NFT_DROP
  DEFI
  DAPP_GROWTH
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum Objective {
  AWARENESS
  WALLET_CONNECTS
  ON_CHAIN_CONVERSION
  TOKEN_HOLDERS
}

enum PricingModel {
  CPM
  CPC
  CPA
}

enum BidStrategy {
  MANUAL
  AUTO
  MAX_CONVERSIONS
  TARGET_CPA
}

enum Pacing {
  STANDARD
  ACCELERATED
  EVEN
}

enum CreativeFormat {
  BANNER
  HTML5
  VIDEO
  NATIVE
}

enum DeviceType {
  DESKTOP
  MOBILE
}

enum AttrEventType {
  IMPRESSION
  CLICK
  WALLET_CONNECT
  ON_CHAIN_CONV
}
